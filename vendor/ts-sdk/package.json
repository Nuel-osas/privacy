{
	"name": "ts-sdk",
	"version": "1.0.0",
	"description": "",
	"main": "index.ts",
	"type": "module",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs",
			"default": "./dist/index.mjs"
		}
	},
	"sideEffects": false,
	"files": [
		"dist"
	],
	"scripts": {
		"clean": "rm -rf tsconfig.tsbuildinfo ./dist",
		"codegen": "(cd ../move && sui move summary -e devnet) && sui-ts-codegen generate && prettier --write src/contracts",
		"build": "rm -rf dist && tsc --noEmit && tsdown",
		"test": "pnpm test:unit",
		"test:unit": "vitest run test/unit/**.test.ts",
		"test:e2e": "vitest run test/e2e",
		"vitest": "vitest",
		"format": "prettier --write .",
		"format:check": "prettier --check ."
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"packageManager": "pnpm@10.10.0",
	"dependencies": {
		"@contra/bulletproofs-wasm": "file:../utils/bulletproofs-wasm",
		"@mysten/bcs": "^2.0.5",
		"@mysten/sui": "^2.17.0",
		"@noble/curves": "^2.2.0",
		"@noble/hashes": "^2.2.0"
	},
	"devDependencies": {
		"@ianvs/prettier-plugin-sort-imports": "^4.7.1",
		"@mysten/codegen": "^0.10.6",
		"contra-utils": "file:../utils/ts-utils",
		"prettier": "^3.8.3",
		"tsdown": "^0.21.10",
		"typescript": "^5.9.3",
		"vitest": "^4.1.8"
	}
}
